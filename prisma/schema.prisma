generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CredentialKind {
  OPENAI_COMPATIBLE
  ANTHROPIC
  GOOGLE
}

model Conversation {
  id           String        @id @default(cuid())
  title        String        @default("New Conversation")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  modelId      String?
  modelLabel   String?
  credentialId String?
  credential   AICredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  messages     Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  files          String?      // JSON array of {url,mediaType,filename} for attached files
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AICredential {
  id            String         @id @default(cuid())
  name          String
  kind          CredentialKind
  apiKey        String
  baseUrl       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@unique([name])
}

// Singleton row (id = "default") that holds global user preferences
model UserSettings {
  id           String   @id @default("default")
  systemPrompt String   @default("")
  updatedAt    DateTime @updatedAt
}
